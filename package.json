{
  "name": "agent-marketplace-sync",
  "displayName": "Agent Marketplace Sync",
  "description": "Sync AI agents, instructions, and skills from awesome-copilot repositories into .github or .claude",
  "version": "1.4.1",
  "publisher": "gardltio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gardlt/vscode-awesome-copilot.git"
  },
  "homepage": "https://github.com/gardlt/vscode-awesome-copilot#readme",
  "bugs": {
    "url": "https://github.com/gardlt/vscode-awesome-copilot/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Extension Packs"
  ],
  "keywords": [
    "copilot",
    "ai",
    "agents",
    "github"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agent-marketplace-sync.configure",
        "title": "Configure Marketplace",
        "category": "Agent Marketplace"
      },
      {
        "command": "agent-marketplace-sync.removeRepository",
        "title": "Remove Repository",
        "category": "Agent Marketplace"
      },
      {
        "command": "agent-marketplace-sync.syncMarketplace",
        "title": "Sync Marketplace",
        "category": "Agent Marketplace"
      },
      {
        "command": "agent-marketplace-sync.initializeStructure",
        "title": "Initialize Project Structure",
        "category": "Agent Marketplace"
      },
      {
        "command": "agent-marketplace-sync.findAndAddAgent",
        "title": "Find and Add Agent",
        "category": "Agent Marketplace"
      },
      {
        "command": "agent-marketplace-sync.findAndAddInstruction",
        "title": "Find and Add Instruction",
        "category": "Agent Marketplace"
      },
      {
        "command": "agent-marketplace-sync.findAndAddSkill",
        "title": "Find and Add Skill",
        "category": "Agent Marketplace"
      },
      {
        "command": "agent-marketplace-sync.findAndAddPlugin",
        "title": "Find and Add Plugin",
        "category": "Agent Marketplace"
      },
      {
        "command": "agent-marketplace-sync.clearCache",
        "title": "Clear Repository Cache",
        "category": "Agent Marketplace"
      },
      {
        "command": "agent-marketplace-sync.showCacheStats",
        "title": "Show Cache Statistics",
        "category": "Agent Marketplace"
      },
      {
        "command": "agent-marketplace-sync.signIn",
        "title": "Sign In with GitHub",
        "category": "Agent Marketplace"
      }
    ],
    "configuration": {
      "title": "Agent Marketplace Sync",
      "properties": {
        "agent-marketplace-sync.targetRepository": {
          "type": "string",
          "default": "github/awesome-copilot",
          "description": "Marketplace repository (format: owner/repo) - matches copilot plugin marketplace"
        },
        "agent-marketplace-sync.branch": {
          "type": "string",
          "default": "main",
          "description": "Branch to sync from"
        },
        "agent-marketplace-sync.autoSync": {
          "type": "boolean",
          "default": false,
          "description": "Automatically sync when workspace opens"
        },
        "agent-marketplace-sync.syncOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Check for updates when saving copilot files"
        },
        "agent-marketplace-sync.baseDirectory": {
          "type": "string",
          "default": ".github",
          "enum": [
            ".github",
            ".claude"
          ],
          "description": "Base directory for storing synced copilot resources"
        },
        "agent-marketplace-sync.repositories": {
          "type": "array",
          "default": [],
          "description": "List of repositories to sync from. When populated, overrides targetRepository/branch settings.",
          "items": {
            "type": "object",
            "required": [
              "repository"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Human-readable name for this repository (defaults to owner/repo)"
              },
              "repository": {
                "type": "string",
                "description": "Repository in owner/repo format"
              },
              "branch": {
                "type": "string",
                "default": "main",
                "description": "Branch to sync from"
              }
            }
          }
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "agent-marketplace-sync.configure"
        },
        {
          "command": "agent-marketplace-sync.initializeStructure"
        },
        {
          "command": "agent-marketplace-sync.findAndAddAgent"
        }
      ]
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:vscode": "npm run pretest && node ./out/test/runTest.js",
    "package": "vsce package",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "20.x",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/vsce": "^2.15.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.5"
  }
}
